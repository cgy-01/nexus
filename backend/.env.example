# =============================================================================
# Nexus AI Backend — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=nexus
POSTGRES_PASSWORD=<replace-with-a-strong-password>
POSTGRES_DB=nexus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://nexus:<replace-with-a-strong-password>@localhost:5432/nexus

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=<replace-with-a-minio-admin-username>
MINIO_ROOT_PASSWORD=<replace-with-a-strong-password>
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<replace-with-a-minio-access-key>
MINIO_SECRET_KEY=<replace-with-a-minio-secret-key>
MINIO_BUCKET=nexus-files

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=<generate-with-python-secrets-token-urlsafe-64>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Email Authentication (SMTP)
# ---------------------------------------------------------------------------
# Configure a dedicated mailbox or transactional email provider before enabling login.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=<replace-with-an-smtp-app-password>
SMTP_FROM_ADDRESS=Nexus AI <mailer@example.com>
SMTP_USE_SSL=false
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=10
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=NexusAI
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:19000

# ---------------------------------------------------------------------------
# LLM Provider (Phase 2+)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_DEFAULT_MODEL=deepseek-v4-flash
# 仅在此声明的模型会显示在客户端模型菜单中，逗号分隔
# LLM_AVAILABLE_MODELS=deepseek-v4-flash,deepseek-v4-pro
# EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Search Provider
# ---------------------------------------------------------------------------
SEARCH_ENABLED=true
SEARCH_DEFAULT_REGION=mainland
SEARCH_PROVIDER_MAINLAND=bocha
BOCHA_API_KEY=
BOCHA_SEARCH_ENDPOINT=https://api.bocha.cn/v1/web-search
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_SECONDS=8

# ---------------------------------------------------------------------------
# Research Agent
# ---------------------------------------------------------------------------
AGENT_MAX_STEPS=4
AGENT_MAX_SEARCHES=3
AGENT_MAX_SOURCES=12
AGENT_TIMEOUT_SECONDS=30
